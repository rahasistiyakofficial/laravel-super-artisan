{
  "name": "rahasistiyak/laravel-super-artisan",
  "description": "A powerful Laravel scaffolding package — generate Models, Controllers, Repositories, APIs, Filament resources, Policies, Actions, and more with a single command. Includes a complete Workflow runner for Artisan command sequences.",
  "version": "2.0.0",
  "type": "library",
  "keywords": [
    "laravel",
    "artisan",
    "scaffolding",
    "generator",
    "workflow",
    "repository-pattern",
    "service-pattern",
    "livewire",
    "vue",
    "react",
    "filament",
    "api",
    "blueprint",
    "domain",
    "code-generation",
    "developer-tools"
  ],
  "homepage": "https://github.com/rahasistiyakofficial/laravel-super-artisan",
  "license": "MIT",
  "authors": [
    {
      "name": "Rahas Istiyak",
      "email": "rahasistiyak.official@gmail.com",
      "homepage": "https://github.com/rahasistiyakofficial"
    }
  ],
  "require": {
    "php": ">=8.2",
    "laravel/framework": "^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "orchestra/testbench": "^9.0"
  },
  "autoload": {
    "psr-4": {
      "RahasIstiyak\\SuperArtisan\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "RahasIstiyak\\SuperArtisan\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "RahasIstiyak\\SuperArtisan\\Providers\\SuperArtisanServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test:coverage": "vendor/bin/phpunit --coverage-text"
  },
  "support": {
    "issues": "https://github.com/rahasistiyakofficial/laravel-super-artisan/issues",
    "source": "https://github.com/rahasistiyakofficial/laravel-super-artisan",
    "docs": "https://github.com/rahasistiyakofficial/laravel-super-artisan#readme"
  }
}